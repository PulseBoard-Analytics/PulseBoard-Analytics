# Database (Neon or Supabase PostgreSQL)
# Neon: get from https://neon.tech -> Project -> Connection string
# Use pooled connection for DATABASE_URL, direct for DIRECT_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-here-min-32-chars"

# App URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth (https://github.com/settings/applications/new)
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"
